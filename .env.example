# Link ingestion APIs
ENSEMBLEDATA_TOKEN=
SUPADATA_API_KEY=

# Place geocoding uses Nominatim (OpenStreetMap) via geopy — no API key needed.

# OpenAI — caption extraction and hierarchy group naming
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DynamoDB Local (docker compose maps host 8001 → container 8000)
# Keep API on uvicorn :8000; Vite proxies /api there.
DYNAMODB_ENDPOINT_URL=http://localhost:8001
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Clerk auth — leave CLERK_ISSUER empty for local X-User-Id mode (auth disabled).
# Production (INGEST_MODE=stepfunctions) requires CLERK_ISSUER; empty issuer is rejected.
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=   # optional; derived from issuer when unset
# CLERK_AUDIENCE=
# ADMIN_USER_IDS=user_xxx,user_yyy
# AUTH_DISABLED=1

# Ingest orchestration: local (BackgroundTasks) or stepfunctions (AWS)
INGEST_MODE=local
# STATE_MACHINE_ARN=arn:aws:states:REGION:ACCOUNT:stateMachine:TravelIngest
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
