# Link ingestion APIs (used by CLI / Lambda; set via CDK deploy for AWS)
ENSEMBLEDATA_TOKEN=
SUPADATA_API_KEY=

# Place geocoding uses Nominatim (OpenStreetMap) via geopy — no API key needed.

# Optional: Google Geocoding fallback when Nominatim is weak (1f — not wired yet)
# GOOGLE_MAPS_API_KEY=

# OpenAI — caption extraction, hierarchy naming, and locate candidate picker (1g)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App logs (CLI + Lambda → CloudWatch). DEBUG includes locate queries/notes.
# LOG_LEVEL=INFO

# Instagram profile → Visited import: how many latest posts to pull (default 5)
# INSTAGRAM_PROFILE_POST_LIMIT=5

# Google Maps Timeline upload: max unique places to reverse-geocode per file (default 150)
# TIMELINE_IMPORT_MAX_PLACES=150
# TIMELINE_IMPORT_MAX_BYTES=41943040

# CLI against TravelPlanner-dev (uses your AWS credentials / default profile)
# DYNAMODB_REGION=us-west-2
# DYNAMODB_STAGE=dev

# Optional: restrict admin routes when running tools against AWS
# ADMIN_USER_IDS=user_xxx,user_yyy
