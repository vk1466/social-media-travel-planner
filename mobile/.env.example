# Point the Expo app at TravelPlanner-dev (stack ApiEndpoint = Function URL, no trailing slash)
EXPO_PUBLIC_API_BASE_URL=https://xxxxxxxx.lambda-url.us-west-2.on.aws

# Clerk publishable key must match the CLERK_ISSUER configured on that stack
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional — required for Google Maps tiles on Android (iOS uses Apple Maps by default)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
